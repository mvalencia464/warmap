# Convex deployment URL (from `npx convex dev` or dashboard)
VITE_CONVEX_URL=

# Clerk → API keys → Publishable key only: pk_test_... or pk_live_... (never the Secret sk_... key)
VITE_CLERK_PUBLISHABLE_KEY=

# Set on the Convex side (Dashboard → Settings → Environment Variables), not in this file:
# CLERK_JWT_ISSUER_DOMAIN — same as Clerk "Frontend API" / issuer (e.g. your-subdomain.clerk.accounts.dev)
